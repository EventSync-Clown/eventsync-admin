generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  matricule String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Participant {
  id        String   @id @default(cuid())
  matricule String   @unique
  password  String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
}

model Session {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  chef        String?
  menuItems   String[]
  createdAt   DateTime @default(now())
}